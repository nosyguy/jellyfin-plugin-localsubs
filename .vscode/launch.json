{
    // Paths and plugin names are configured in settings.json
    "version": "0.2.0",
    "configurations": [
        {
            "type": "coreclr",
            "name": "Launch",
            "request": "launch",
            "preLaunchTask": "build-and-copy",
            "program": "${config:jellyfinServerDir}/bin/Debug/${config:targetFramework}/jellyfin.dll",
            "args": [
                "--datadir",
                "${config:jellyfinDataDir}/",
                "--webdir",
                "${config:jellyfinWebDir}/dist/"
            ],
            "cwd": "${config:jellyfinServerDir}"
        }
    ]
}
